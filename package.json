{
  "name": "nexus",
  "private": true,
  "version": "1.0.0",
  "description": "ALMAJD: Connect. Collaborate. Create.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,green \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "mobile:web": "npm run build:mobile --workspace frontend",
    "mobile:sync": "npm run mobile:web && npx cap sync ios",
    "mobile:sync:ios": "npm run mobile:web && npx cap sync ios",
    "mobile:build": "npm run mobile:sync:ios",
    "mobile:open:ios": "npx cap open ios",
    "mobile:run:ios": "npx cap run ios",
    "test:auth": "npm run test:auth --workspace backend",
    "test:chat": "npm run test:chat --workspace backend",
    "test": "npm run test:auth && npm run test:chat",
    "lint": "npm run lint --workspace frontend"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "concurrently": "^9.1.2"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0"
  }
}
