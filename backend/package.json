{
  "name": "@nexus/backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:azure": "node scripts/apply-sqlite-migrations.mjs && node dist/server.js",
    "start:render": "node scripts/apply-sqlite-migrations.mjs && node dist/server.js",
    "postinstall": "prisma generate",
    "test:auth": "vitest run src/modules/auth/auth.routes.test.ts src/utils/auth.test.ts",
    "test:chat": "vitest run src/modules/conversations/chat.routes.test.ts src/modules/conversations/file-upload.test.ts src/modules/messages/message-edit-delete.test.ts src/modules/groups/groups.routes.test.ts src/modules/guests/guest-mode.test.ts src/socket/socket.integration.test.ts src/socket/notify.test.ts src/socket/group-notify.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node scripts/apply-sqlite-migrations.mjs",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.19.3",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
